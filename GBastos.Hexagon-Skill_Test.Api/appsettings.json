{
  "DatabaseProvider": "SqlServer",
  "ConnectionStrings": {
    "SqlServer": "Server=sqlserver,1433;Database=HexagonDb;User Id=sa;Password=${SA_PASSWORD};TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "${JWT_KEY}"
  },
  "RabbitMQ": {
    "HostName": "${RABBITMQ_HOSTNAME}",
    "QueueName": "usuarios",
    "Username": "${RABBITMQ_DEFAULT_USER}",
    "Password": "${RABBITMQ_DEFAULT_PASS}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}